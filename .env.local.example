# WordPress GraphQL
NEXT_PUBLIC_WORDPRESS_GRAPHQL_URL=https://wp.yourdomain.com/graphql
REVALIDATE_SECRET=replace-with-a-long-random-secret

# Brevo Newsletter
BREVO_API_KEY=your-brevo-api-key
BREVO_LIST_ID=3

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Security
IP_SALT=replace-with-a-long-random-secret

# Admin Dashboard
# Put real values only in Vercel Environment Variables. Do not commit real secrets.
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-password
ADMIN_SECRET=replace-with-a-long-random-secret

# Web Push (VAPID)
# Generate with: node -e "const w=require('web-push');console.log(w.generateVAPIDKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@yourdomain.com


# Real Article Views Counter
# WordPress backend base URL, not the GraphQL URL. Example: https://wp.yourdomain.com
WORDPRESS_REST_URL=https://wp.yourdomain.com
# Legacy views secret, only needed if you still use the old views-only plugin.
EONAI_VIEW_KEY=replace-with-a-long-random-secret

# EONAI Engagement Plugin
# Must match define('EONAI_ENGAGEMENT_KEY', '...') in wp-config.php
EONAI_ENGAGEMENT_KEY=replace-with-a-long-random-secret

# Google Login for Comments
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_URL=https://everydayonai.com
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google AdSense
# These IDs are public publisher identifiers, not secrets.
NEXT_PUBLIC_ADSENSE_ENABLED=true
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-2629543840580780
ADSENSE_PUBLISHER_ID=pub-2629543840580780
NEXT_PUBLIC_ADSENSE_SLOT_HOME_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_HOME_INFEED=
NEXT_PUBLIC_ADSENSE_SLOT_HOME_BOTTOM=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR_BOTTOM=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_BOTTOM=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLES_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_TOOLS_TOP=

# Site URL
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
