# ─── WordPress GraphQL ───────────────────────────────────────────
NEXT_PUBLIC_WORDPRESS_GRAPHQL_URL=https://wp.yourdomain.com/graphql
REVALIDATE_SECRET=ganti-dengan-random-string-panjang

# ─── Brevo Newsletter ────────────────────────────────────────────
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_LIST_ID=3

# ─── Supabase ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Security ────────────────────────────────────────────────────
IP_SALT=ganti-dengan-random-string

# ─── Admin Dashboard ─────────────────────────────────────────────
# Isi nilai asli di Vercel Environment Variables, JANGAN di sini
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-password
ADMIN_SECRET=ganti-dengan-random-string-panjang

# ─── Web Push (VAPID) ────────────────────────────────────────────
# Generate dengan: node -e "const w=require('web-push');console.log(w.generateVAPIDKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@yourdomain.com


# ─── Real Article Views Counter ─────────────────────────────────
# Base URL WordPress backend, bukan URL GraphQL. Contoh: https://wp.yourdomain.com
WORDPRESS_REST_URL=https://wp.yourdomain.com
# Legacy views secret, only needed if you still use the old views-only plugin.
EONAI_VIEW_KEY=ganti-dengan-random-string-panjang

# ─── EONAI Engagement Plugin ────────────────────────────────────
# Harus sama dengan define('EONAI_ENGAGEMENT_KEY', '...') di wp-config.php
EONAI_ENGAGEMENT_KEY=ganti-dengan-random-string-panjang

# ─── Google Login for Comments ──────────────────────────────────
# Generate AUTH_SECRET dengan: openssl rand -base64 32
AUTH_SECRET=ganti-dengan-random-string-panjang
AUTH_URL=https://everydayonai.com
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# ─── Google Analytics ───────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Google AdSense (isi setelah approved) ─────────────────────
NEXT_PUBLIC_ADSENSE_ENABLED=false
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
ADSENSE_PUBLISHER_ID=pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_HOME_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_HOME_INFEED=
NEXT_PUBLIC_ADSENSE_SLOT_HOME_BOTTOM=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR_BOTTOM=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_BOTTOM=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLES_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_TOOLS_TOP=

# ─── Site URL ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
