# ─── WordPress GraphQL ───────────────────────────────────────────
NEXT_PUBLIC_WORDPRESS_GRAPHQL_URL=https://wp.yourdomain.com/graphql
REVALIDATE_SECRET=ganti-dengan-random-string-panjang

# ─── Brevo Newsletter ────────────────────────────────────────────
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_LIST_ID=3

# ─── Supabase ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Security ────────────────────────────────────────────────────
IP_SALT=ganti-dengan-random-string

# ─── Admin Dashboard ─────────────────────────────────────────────
# Isi nilai asli di Vercel Environment Variables, JANGAN di sini
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-password
ADMIN_SECRET=ganti-dengan-random-string-panjang

# ─── Web Push (VAPID) ────────────────────────────────────────────
# Generate dengan: node -e "const w=require('web-push');console.log(w.generateVAPIDKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@yourdomain.com

# ─── Google Analytics ───────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Google AdSense (isi setelah approved) ─────────────────────
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-6538117569596224

# ─── Site URL ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
